                                "descriptions": {
                                    "__typename": "StaySupplyListingDescriptions",
                                    "id": "U3RheVN1cHBseUxpc3RpbmdEZXNjcmlwdGlvbnM6MTA2NTE2MjIwMzQxNjgyNDc3MQ==",
                                    "descriptions": [
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "NAME",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "NourTinyFootprint Getaway 1"
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "SUMMARY",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "Welcome to Nour Tiny Footprint Getaway 1\nEmbrace adventure where the essence of living lies in simplicity and mindful connection with nature. Enjoy birdwatching, surfing, hiking or writing immersed in nature with a a taste of life beyond consumerism. \nExperience the charm of our thoughtfully designed for sustainability tinyhouse nestled in the heart of a tropical forest minutes away from World-Class surfing.   Participate in the initial stages of our project and contribute to the ongoing evolution"
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "SPACE",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "The Tiny footprint Getaway\n\nIs a 35m2 tiny house with plenty of windows for you to enjoy the outdoor scenery. It features a yoga mini loft,  main bedroom loft, open kitchen, living room area and an enjoyable outdoors balcony. \n\nThe kitchen is fully equiped with cooking utensils, a mini oven, and a mini fridge.  The bathroom has a full cold shower bathroom, and a waterless, eco-friendly dry toilet with urine divertion. \n\nSituated on an ample property, with other house, where secondary forest preservation is being prioritized.  Access involves walking uphill. The property offers outdoor spaces for birdwatching, reading, and relaxation. A river and hiking trails with ocean views are nearby.\n\nConveniently located, we're a 15-minute drive from Playa Hermosa and 20 minutes from Jacó. Experience tranquility and eco-conscious living at the Tiny Footprint Getaway."
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "INTERACTION",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "Happy to answer any message providing assitance on your stay or planning your trip around the area or my beautiful country. \n\nWe might be at home to meet too."
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "ACCESS",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "Access is intentionally challenging, ensuring a journey that resonates with the intrepid adventure seeking individuals.\n\n-ONLY 4x4\n-Terrible shape access road!\n-Gravel with potholes!\n-River crossing!\n-At night there's little light\n\nJust as Costa Rican rural areas, if you haven't  drive around, this will be just a preparation for your trip in wild and natural surrounded v areas."
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "NOTES",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "You will be immersed in nature, this also means:\n- Monkey visits\n- Morning bird orchestra\n- Plenty of insects and mosquitos as any mountain retreat.\n- Electricity might fail once every 3 months  ( we will provide a gas mini and candels stove if this happens )\n\nReview the sustainability features which include dry toilet and organic/recyclable waste separation."
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "HOUSE_RULES",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "Please follow the instructions in the house manual :)"
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "NEIGHBORHOOD_OVERVIEW",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": null
                                                }
                                            ]
                                        },
                                        {
                                            "__typename": "StaySupplyListingDescription",
                                            "descriptionType": "TRANSIT",
                                            "values": [
                                                {
                                                    "__typename": "ListingUGC",
                                                    "language": "en",
                                                    "languageName": "English",
                                                    "value": "The best way to move around is a  4x4 car. \nTaxis are also available, and if you are more energetic we have bikes too!"
                                                }
                                            ]
                                        }
