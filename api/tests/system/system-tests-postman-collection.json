			"name": "Register user",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const userId = pm.response.json()._id;",
							"pm.environment.set(\"userId\", userId);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"Olga\",\n    \"email\": \"olga@cloud.com\",\n    \"password\": \"1234567890\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseURL}}/api/users/register",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"api",
						"users",
						"register"
					]
				}
			},
			"response": []
		},
