# ─────────────────────────────────────────────────────────────────────────────
# Smarter Stays – API environment variables
# Copy this file to .env and fill in the values marked with <...>
#   cp api/.env.example api/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────────────────────

# Port the Node.js API listens on
PORT=3000

# ── MongoDB ───────────────────────────────────────────────────────────────────

# Connection protocol. Use "mongodb" for the local Docker instance (default).
# Use "mongodb+srv" only if connecting to MongoDB Atlas.
DB_PREFIX=mongodb

# MongoDB credentials – these values also initialise the Docker container on
# first run, so choose them once and keep them consistent.
DB_USER=admin
DB_PASSWORD=<choose-a-strong-password>

# When running via Docker Compose use the service name "mongo" as the host.
# Change only if you are connecting to an external/Atlas cluster.
DB_DOMAIN=mongo

# The database name that will be created inside MongoDB.
DB_NAME=smarter-stays

# MongoDB port. 27017 is the default; matches the port mapping in docker-compose.yaml.
DB_PORT=27017

# ── JWT Authentication ────────────────────────────────────────────────────────

# Secret used to sign and verify JSON Web Tokens.
# Generate a random value, e.g.:  openssl rand -hex 32
TOKEN_SECRET=<replace-with-a-random-secret-string>

# ── ThingsBoard ───────────────────────────────────────────────────────────────

# Internal URL for the ThingsBoard service when running via Docker Compose.
# If ThingsBoard is hosted externally, update this to the remote URL.
THINGSBOARD_URL=http://mytb:9090

# ThingsBoard tenant credentials.
# Default values for a fresh ThingsBoard installation are shown below.
# You should change the password after the first login at http://localhost:8080.
THINGSBOARD_USERNAME=tenant@thingsboard.org
THINGSBOARD_PASSWORD=tenant

# Device provisioning credentials.
# Leave these as "auto_provisioned" – start.sh will replace them automatically
# by querying the ThingsBoard API during startup.
PROVISION_DEVICE_KEY=auto_provisioned
PROVISION_DEVICE_SECRET=auto_provisioned
